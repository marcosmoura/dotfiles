{
  "$schema": "https://opencode.ai/config.json",

  "instructions": ["~/.config/opencode/rules/*.md"],

  "model": "openai/gpt-5.5",
  "small_model": "github-copilot/claude-haiku-4.5",

  "provider": {
    "CrofAI": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "CrofAI",
      "options": {
        "baseURL": "https://crof.ai/v1",
        "apiKey": "{file:~/.secrets/crof}"
      },
      "models": {
        "deepseek-v4-pro": {
          "name": "DeepSeek v4",
          "limit": { "context": 1000000, "output": 131072 }
        },
        "deepseek-v4-pro-precision": {
          "name": "DeepSeek v4 Precision",
          "limit": { "context": 1000000, "output": 131072 }
        },
        "deepseek-v4-flash": {
          "name": "DeepSeek v4 Flash",
          "limit": { "context": 1000000, "output": 131072 }
        },
        "kimi-k2.6": {
          "name": "Kimi k2.6",
          "limit": { "context": 262144, "output": 262144 }
        },
        "kimi-k2.6-precision": {
          "name": "Kimi k2.6 Precision",
          "limit": { "context": 262144, "output": 262144 }
        },
        "glm-5.1": {
          "name": "GLM 5.1",
          "limit": { "context": 202752, "output": 202752 }
        },
        "glm-5.1-precision": {
          "name": "GLM 5.1 Precision",
          "limit": { "context": 202752, "output": 202752 }
        }
      }
    }
  },

  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true,
      "headers": {
        "CONTEXT7_API_KEY": "{file:~/.secrets/context7-key}"
      }
    },

    "grep": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.grep.app"
    },

    "github": {
      "enabled": true,
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "{file:~/.secrets/gh-pat-key}"
      }
    }
  },

  "permission": {
    "bash": {
      "*": "allow",
      "echo *": "allow",
      "git worktree *": "allow",
      "git branch *": "allow",
      "grep *": "allow",
      "git -C *": "allow",
      "cargo check *": "allow",
      "cargo test *": "allow",
      "gh pr create *": "allow",
      "cat *": "allow",
      "git rev-parse *": "allow",
      "git ls-remote *": "allow",
      "chmod *": "ask",
      "chown *": "ask",
      "fd *": "allow",
      "find . *": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git show*": "allow",
      "git status*": "allow",
      "grep -r *": "allow",
      "head *": "allow",
      "ls *": "allow",
      "node -e *": "allow",
      "pwd": "allow",
      "python -c *": "allow",
      "rg *": "allow",
      "rm -rf *": "deny",
      "sudo *": "deny",
      "tail *": "allow",
      "type *": "allow",
      "wc *": "allow",
      "which *": "allow"
    },
    "codesearch": "allow",
    "edit": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "lsp": "allow",
    "read": "allow",
    "skill": "allow",
    "task": "allow",
    "todoread": "allow",
    "todowrite": "allow",
    "webfetch": "allow",
    "websearch": "allow"
  },

  "plugin": [
    "@mohak34/opencode-notifier@latest",
    "@franlol/opencode-md-table-formatter@latest",
    "superpowers@git+https://github.com/obra/superpowers.git"
  ]
}
