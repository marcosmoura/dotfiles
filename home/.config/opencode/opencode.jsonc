{
  "$schema": "https://opencode.ai/config.json",

  "instructions": ["~/.config/opencode/rules/*.md"],

  "model": "fireworks-ai/accounts/fireworks/routers/kimi-k2p5-turbo",
  "small_model": "opencode-go/kimi-k2.5",

  "agent": {
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    }
  },

  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true,
      "headers": {
        "CONTEXT7_API_KEY": "{file:~/.secrets/context7-key}"
      }
    },

    "gh_grep": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.grep.app"
    },

    "github": {
      "enabled": true,
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "{file:~/.secrets/gh-pat-key}"
      }
    }
  },

  "permission": {
    "bash": {
      "*": "allow",
      "echo *": "allow",
      "git worktree *": "allow",
      "git branch *": "allow",
      "grep *": "allow",
      "git -C *": "allow",
      "cargo check *": "allow",
      "cargo test *": "allow",
      "gh pr create *": "allow",
      "cat *": "allow",
      "git rev-parse *": "allow",
      "git ls-remote *": "allow",
      "chmod *": "ask",
      "chown *": "ask",
      "fd *": "allow",
      "find . *": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git show*": "allow",
      "git status*": "allow",
      "grep -r *": "allow",
      "head *": "allow",
      "ls *": "allow",
      "node -e *": "allow",
      "pwd": "allow",
      "python -c *": "allow",
      "rg *": "allow",
      "rm -rf *": "deny",
      "sudo *": "deny",
      "tail *": "allow",
      "type *": "allow",
      "wc *": "allow",
      "which *": "allow"
    },
    "codesearch": "allow",
    "edit": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "lsp": "allow",
    "read": "allow",
    "skill": "allow",
    "task": "allow",
    "todoread": "allow",
    "todowrite": "allow",
    "webfetch": "allow",
    "websearch": "allow"
  },

  "plugin": [
    "@mohak34/opencode-notifier@latest",
    "@franlol/opencode-md-table-formatter@latest",
    "@ex-machina/opencode-anthropic-auth@latest",
    "oh-my-opencode-slim@latest"
  ]
}
