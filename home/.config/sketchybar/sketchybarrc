#!/usr/bin/env bash
set -euo pipefail

export CONFIG_DIR="$HOME/.config/sketchybar"
export SBAR_LUA_DIR="$HOME/.local/share/sketchybar_lua"

# Install SbarLua if not present
if [ ! -f "$SBAR_LUA_DIR/sketchybar.so" ]; then
  if ! source "$CONFIG_DIR/scripts/install_sbarlua.sh"; then
    echo "Failed to bootstrap SbarLua." >&2
    exit 1
  fi
fi

if [ ! -f "$SBAR_LUA_DIR/sketchybar.so" ]; then
  echo "Missing $SBAR_LUA_DIR/sketchybar.so after SbarLua bootstrap." >&2
  exit 1
fi

if ! command -v lua >/dev/null 2>&1; then
  echo "Missing lua interpreter." >&2
  exit 1
fi

# Launch the Lua configuration
exec lua "$CONFIG_DIR/init.lua"
