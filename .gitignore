# ============================================================
# Dotfiles repository ignore rules
# ============================================================

# Worktrees and build artifacts
.worktrees/
.cache/
/dist
node_modules/

# Sensitive app data (never commit)
home/.config/gh/hosts.yml
home/.config/github-copilot/
home/.config/mole/
home/.config/raycast/
home/.config/stache/.env
home/.config/yarn/
home/.config/yazi/plugins/
home/.config/opencode/opencode-notifier-state.json
home/.config/sheldon/plugins.lock
home/.config/sheldon/repos/

# Git identity (machine-specific, created by install.sh)
home/.config/git/identity

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk

# Environment files
.env.local
.env.*.local

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editor artifacts
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Rust build artifacts
**/target/
**/*.rs.bk

# Claude Code (allow specific config files)
.claude.json
home/.claude/*
!home/.claude/CLAUDE.md
!home/.claude/RTK.md
!home/.claude/settings.json
!home/.claude/statusline.json

# Codex (allow specific config files)
home/.codex/*
!home/.codex/AGENTS.md
!home/.codex/config.toml
!home/.codex/RTK.md
!home/.codex/rules/
