# ============================================================
# Dotfiles repository ignore rules
# ============================================================

# Worktrees and build artifacts
.worktrees/
.cache/
/dist
node_modules/

# SSH config (contains server IPs — managed outside repo)
home/.ssh-config

# Sensitive app data (never commit)
home/.config/gh/hosts.yml
home/.config/direnv/
home/.config/raycast/
home/.config/yarn/

# Git identity (machine-specific, created by install.sh)
home/.config/git/identity

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk

# Environment files
.env.local
.env.*.local

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editor artifacts
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Rust build artifacts
**/target/
**/*.rs.bk

# Claude Code (allow specific config files)
.claude.json
home/.claude/*
!home/.claude/CLAUDE.md
!home/.claude/settings.json
!home/.claude/statusline.json
